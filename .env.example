# ====================================================================
# Central Play Plus TV — Variáveis de ambiente (preencher no Codex)
# ====================================================================

# Banco de dados — Neon Postgres (fornecido pela integração)
DATABASE_URL=

# Cache / rate limit / sessões ao vivo — Upstash Redis (fornecido pela integração)
KV_REST_API_URL=
KV_REST_API_TOKEN=
REDIS_URL=

# Chave do painel administrativo (protege /api/admin/*)
ADMIN_API_KEY=

# Segredo do Vercel Cron (protege /api/cron/health-check)
CRON_SECRET=

# Segredos de assinatura dos tokens dos aparelhos
TV_ACCESS_TOKEN_SECRET=
TV_REFRESH_TOKEN_SECRET=

# Base pública da API (usada para montar links proxados)
PUBLIC_API_BASE_URL=https://api.centralplayplus.com.br

# Auto-synced environment variables used by code
APK_PUBLIC_URL=
APK_SHA256=
CATALOG_CACHE_TTL_SECONDS=300
HEALTH_CHECK_BATCH_SIZE=20
HEALTH_CHECK_TIMEOUT_MS=8000
TMDB_API_KEY=
TMDB_ENRICH_LIMIT=30
TMDB_READ_TOKEN=
TV_ACCESS_TOKEN_TTL_SECONDS=3600
TV_MAX_START_TIME_MS=8000
TV_POLL_INTERVAL_SECONDS=5
TV_REFRESH_TOKEN_TTL_SECONDS=2592000
TV_STREAM_TOKEN_SECRET=
TV_STREAM_TOKEN_TTL_SECONDS=300
XTREAM_BASE_URL=
XTREAM_PASSWORD=
XTREAM_SERVER_ID=main
XTREAM_SERVER_NAME=Principal
XTREAM_TIMEOUT_MS=15000
XTREAM_USERNAME=
YELLOWBOX_API_URL=
YELLOW_BOX_API_KEY=
YELLOW_BOX_API_URL=
YELLOW_BOX_FULL_API_URL=
