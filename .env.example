# ====================================================================
# Central Play Plus TV — Variáveis de ambiente (preencher no Codex)
# ====================================================================

# Banco de dados — Neon Postgres (fornecido pela integração)
DATABASE_URL=

# Cache / rate limit / sessões ao vivo — Upstash Redis (fornecido pela integração)
KV_REST_API_URL=
KV_REST_API_TOKEN=
REDIS_URL=

# Chave do painel administrativo (protege /api/admin/*)
ADMIN_API_KEY=

# Segredo do Vercel Cron (protege /api/cron/health-check)
CRON_SECRET=

# Segredos de assinatura dos tokens dos aparelhos
TV_ACCESS_TOKEN_SECRET=
TV_REFRESH_TOKEN_SECRET=

# Base pública da API (usada para montar links proxados)
PUBLIC_API_BASE_URL=https://api.centralplayplus.com.br
